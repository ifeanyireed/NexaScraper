# Nigerian Business Scraper Configuration (.env)

# Scraper Settings
HEADLESS_BROWSER=true
MAX_WORKERS=3
DELAY_BETWEEN_REQUESTS_MIN=2
DELAY_BETWEEN_REQUESTS_MAX=5
MAX_RETRIES=3
TIMEOUT_SECONDS=30

# Data Cleaning
PHONE_STANDARDIZATION=true
ADDRESS_GEOCODING=true
GHOST_BUSINESS_DETECTION=true
DAYS_INACTIVE_THRESHOLD=730

# Proxy Settings (Optional - for production)
USE_PROXY=false
PROXY_ROTATION=false
RESIDENTIAL_PROXY_LIST=

# Output Settings
OUTPUT_FORMAT=csv,json,excel
OUTPUT_DIRECTORY=data/

# Google Sheets Integration (Optional - for real-time cloud storage)
# Get SHEET_ID from your Google Sheet URL: docs.google.com/spreadsheets/d/{SHEET_ID}/edit
SHEET_ID=1-4bDsk7Fe4lRTDWQj-rf81EwIuEzpYK2HGPSgkkvFKU
# Path to Google Service Account JSON file (see setup instructions below)
GOOGLE_APPLICATION_CREDENTIALS=./secure_keys/my-service-account.json

# API Keys (Optional - for enhanced features)
# GOOGLE_MAPS_API_KEY=
# GEOPY_SERVICE=nominatim

# Logging
LOG_LEVEL=INFO
LOG_FILE=scraper.log

# Scraper Sources to Use
ENABLE_GOOGLE_MAPS=true
ENABLE_YELLOWPAGES=true
ENABLE_INSTAGRAM=false
ENABLE_CAC_LOOKUP=false

# Search Strategy
SCRAPING_MODE=priority  # test, priority, full
PRIORITY_CITIES=Lagos,Abuja,Kano,Rivers,Enugu
MAX_QUERIES_PER_BATCH=10
